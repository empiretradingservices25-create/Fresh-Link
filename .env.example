# Environment Variables
# Copy this file to .env.local and fill in your values

# Add your environment variables here
# NEXT_PUBLIC_API_URL=
# DATABASE_URL=



# ─── AI / LLM configuration (server-side only — never use NEXT_PUBLIC_ prefix) ─
# Base URL for the LLM provider (defaults to https://llm.blackbox.ai/chat/completions)
# AI_ENDPOINT=https://llm.blackbox.ai/chat/completions

# Customer ID sent as a request header (if required by your provider)
# AI_CUSTOMER_ID=your_customer_id_here

# Secret API key sent as Authorization: Bearer <key>
# AI_API_KEY=your_api_key_here

# Comma-separated list of model names to try in order (fallback chain)
# AI_MODEL_CHAIN=openrouter/claude-sonnet-4,openrouter/anthropic/claude-3.5-haiku,openrouter/openai/gpt-4o-mini,openrouter/google/gemini-flash-1.5
