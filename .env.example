# Environment Variables
# Copy this file to .env.local and fill in your values

# Add your environment variables here
# NEXT_PUBLIC_API_URL=
# DATABASE_URL=

# ─── AI / LLM configuration ──────────────────────────────────────────────────
# Provider: "blackbox" | "openrouter" | "openai"
AI_PROVIDER=blackbox

# Blackbox AI credentials (https://llm.blackbox.ai)
BLACKBOX_CUSTOMER_ID=your_customer_id_here
BLACKBOX_API_KEY=your_api_key_here

# Optional: OpenRouter API key (used when AI_PROVIDER=openrouter)
# OPENROUTER_API_KEY=
